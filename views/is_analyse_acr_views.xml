<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="is_analyse_acr_tree" model="ir.ui.view">
        <field name="name">is.analyse.acr.tree</field>
        <field name="model">is.analyse.acr</field>
        <field name="arch" type="xml">
            <list create="0" edit="0" delete="0" default_order="ordre">
                <field name="consultant" widget="html" string="Consultant"/>
                <field name="mois_1"    widget="html"/>
                <field name="mois_2"    widget="html"/>
                <field name="mois_3"    widget="html"/>
                <field name="mois_4"    widget="html"/>
                <field name="mois_5"    widget="html"/>
                <field name="mois_6"    widget="html"/>
                <field name="mois_7"    widget="html"/>
                <field name="mois_8"    widget="html"/>
                <field name="mois_9"    widget="html"/>
                <field name="mois_10"   widget="html"/>
                <field name="mois_11"   widget="html"/>
                <field name="mois_12"      widget="html"/>
                <field name="total_12_mois" widget="html"/>
            </list>
        </field>
    </record>

    <!-- Action serveur : régénère les données et ouvre la vue -->
    <record id="is_analyse_acr_search" model="ir.ui.view">
        <field name="name">is.analyse.acr.search</field>
        <field name="model">is.analyse.acr</field>
        <field name="arch" type="xml">
            <search>
                <field name="consultant" filter_domain="[('consultant','ilike',self)]"/>
            </search>
        </field>
    </record>
    <record id="is_analyse_acr_action" model="ir.actions.server">
        <field name="name">Analyse ACR disponibilité</field>
        <field name="model_id" ref="model_is_analyse_acr"/>
        <field name="state">code</field>
        <field name="code">action = model.action_generer('disponibilite')</field>
    </record>
    <record id="is_analyse_acr_charge_action" model="ir.actions.server">
        <field name="name">Analyse ACR charge</field>
        <field name="model_id" ref="model_is_analyse_acr"/>
        <field name="state">code</field>
        <field name="code">action = model.action_generer('charge')</field>
    </record>
    <record id="is_analyse_acr_delta_action" model="ir.actions.server">
        <field name="name">Analyse ACR reste dispo</field>
        <field name="model_id" ref="model_is_analyse_acr"/>
        <field name="state">code</field>
        <field name="code">action = model.action_generer('delta')</field>
    </record>

</odoo>

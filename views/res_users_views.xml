<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.ui.view" id="is_view_users_form">
        <field name="name">is_view_users_form</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('oe_title')][1]" position="after">
                <group>
                    <field name="is_initiales"/>
                    <field name="is_compte_general"/>
                    <field name="is_dynacase_ids" widget="many2many_tags" groups="base.group_system"/>
                </group>
            </xpath>
            <group name="preferences" position="before">
                <group string="Consultant" groups="is_opta_s18.is_administratif_group">
                    <field name="is_nb_jours"/>
                    <field name="is_salaire_an"/>
                    <field name="is_salaire_jour"/>
                    <field name="is_taux_disponibilite"/>
                </group>
            </group>
        </field>
    </record>
    <record model="ir.ui.view" id="is_view_users_tree">
        <field name="name">is_view_users_tree</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_tree"/>
        <field name="arch" type="xml">
            <field name="login" position="after">
                <field name="is_initiales"/>
                <field name="is_compte_general"/>
                <field name="is_dynacase_ids" widget="many2many_tags" groups="base.group_system"/>
            </field>
        </field>
    </record>

    <!-- Vue liste ACR taux de disponibilité -->
    <record model="ir.ui.view" id="is_users_taux_dispo_tree">
        <field name="name">is_users_taux_dispo_tree</field>
        <field name="model">res.users</field>
        <field name="priority">999</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="is_can_edit_taux" column_invisible="1"/>
                <field name="name"                  readonly="1"/>
                <field name="is_taux_disponibilite" readonly="not is_can_edit_taux"/>
            </list>
        </field>
    </record>
    <record model="ir.ui.view" id="is_users_taux_dispo_search">
        <field name="name">is_users_taux_dispo_search</field>
        <field name="model">res.users</field>
        <field name="priority">999</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter string="Mon taux de disponibilité" name="mon_taux" domain="[('id','=',uid)]"/>
            </search>
        </field>
    </record>
    <record id="is_users_taux_dispo_action" model="ir.actions.act_window">
        <field name="name">Taux de disponibilité par utilisateur</field>
        <field name="res_model">res.users</field>
        <field name="limit">200</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="is_users_taux_dispo_tree"/>
        <field name="search_view_id" ref="is_users_taux_dispo_search"/>
        <field name="context">{'search_default_mon_taux': 1}</field>
    </record>
    <record model="ir.ui.view" id="is_view_users_simple_form">
        <field name="name">is_view_users_simple_form</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_simple_form"/>
        <field name="arch" type="xml">
            <group name="phone_numbers" position="after">
                <group string="Consultant">
                    <field name="is_taux_disponibilite"/>
                </group>
            </group>
        </field>
    </record>

</odoo>
